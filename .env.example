# Copy to .env.development | .env.uat | .env.production or add local overrides:
#   .env.development.local (gitignored)
#
# Pick environment when starting Metro / bundling:
#   APP_ENV=development npm start
#   APP_ENV=uat npm run start:uat
#   APP_ENV=production npm run start:production
#
# Android release: npm run android:release:uat / android:release:prod (sets APP_ENV for bundle).

APP_ENV=development
# Bật HTTP thật cho LogsApi (GET/PUT /api/v1/logs). Để trống = chỉ fixture (không gọi host).
# Khi có URL nhưng host không tới được (vd. localhost trên Android emulator), bản **development**
# sẽ tự fallback fixture cho GET và mô phỏng PUT — UAT/production không fallback.
API_BASE_URL=
ENABLE_DEBUG_LOGGING=true
FEATURE_SYNC_ENABLED=true
