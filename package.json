{
  "name": "farming",
  "version": "1.0.15",
  "private": true,
  "scripts": {
    "start": "cross-env APP_ENV=development react-native start",
    "start:uat": "cross-env APP_ENV=uat react-native start",
    "start:production": "cross-env APP_ENV=production react-native start",
    "android": "cross-env APP_ENV=development react-native run-android --mode devDebug",
    "android:uat": "cross-env APP_ENV=uat react-native run-android --mode uatDebug",
    "android:prod": "cross-env APP_ENV=production react-native run-android --mode prodDebug",
    "android:release:dev": "cross-env APP_ENV=development sh -c 'cd android && ./gradlew assembleDevRelease'",
    "android:release:uat": "cross-env APP_ENV=uat sh -c 'cd android && ./gradlew assembleUatRelease'",
    "android:release:prod": "cross-env APP_ENV=production sh -c 'cd android && ./gradlew assembleProdRelease'",
    "version:bump": "node scripts/bump-app-version.mjs",
    "icons:generate": "bash scripts/generate-app-icons.sh",
    "db:export": "bash scripts/exportDb.sh",
    "migrate:schema": "tsx scripts/migrateSchema.ts",
    "ios": "cross-env APP_ENV=development react-native run-ios",
    "ios:uat": "cross-env APP_ENV=uat react-native run-ios",
    "ios:production": "cross-env APP_ENV=production react-native run-ios",
    "ios:production:release": "cross-env APP_ENV=production react-native run-ios --mode Release",
    "ios:fonts-plist": "rnvi-update-plist package.json ios/farming/Info.plist",
    "lint": "eslint .",
    "postinstall": "patch-package",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-masked-view/masked-view": "^0.2.9",
    "@react-native-vector-icons/material-design-icons": "^13.1.0",
    "@react-native/new-app-screen": "0.85.1",
    "@react-navigation/drawer": "^7.9.8",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@reduxjs/toolkit": "^2.11.2",
    "i18next": "^26.0.5",
    "react": "19.2.3",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.4",
    "react-native": "0.85.1",
    "react-native-background-fetch": "^4.4.2",
    "react-native-bootsplash": "^7.3.1",
    "react-native-device-info": "^15.0.2",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-localize": "^3.7.0",
    "react-native-paper": "^5.15.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-worklets": "^0.8.1",
    "react-redux": "^9.2.0",
    "redux-saga": "^1.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.1",
    "@react-native/eslint-config": "0.85.1",
    "@react-native/jest-preset": "0.85.1",
    "@react-native/metro-config": "0.85.1",
    "@react-native/typescript-config": "0.85.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-sqlite-storage": "^6.0.5",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.19.0",
    "eslint-plugin-ft-flow": "^3.0.11",
    "jest": "^29.6.3",
    "patch-package": "^8.0.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "sql.js": "^1.13.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
