{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "resolveJsonModule": true,
    "strict": true,
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@config/*": ["src/config/*"],
      "@domain/*": ["src/domain/*"],
      "@data/*": ["src/data/*"],
      "@services/*": ["src/services/*"],
      "@features/*": ["src/features/*"],
      "@libs/*": ["src/libs/*"],
      "@ui/*": ["src/ui/*"],
      "@locales/*": ["src/locales/*"]
    }
  },
  "include": ["src", "App.tsx", "index.js", "__tests__"]
}
